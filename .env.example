# LLM - Groq (free at console.groq.com)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings - HuggingFace Inference API (free at huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Long-term memory - Qdrant Cloud (free at cloud.qdrant.io)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Short-term memory - Upstash Redis (free at upstash.com)
# Use the "Redis URL" from the Upstash console (starts with rediss://)
REDIS_URL=rediss://default:your_token@your-endpoint.upstash.io:6379

# Checkpoint store - Neon Postgres (free at neon.tech)
# Copy the "Connection string" from the Neon console
POSTGRES_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# API
API_SECRET_KEY=changeme-generate-a-real-secret
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Frontend (Vite)
VITE_API_URL=https://your-backend.onrender.com
